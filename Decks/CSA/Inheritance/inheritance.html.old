<!-- ============================================================
     SLIDE 22 · INTERFACES
     ============================================================ -->
<section>
  <div class="glow" style="width:440px;height:440px;background:radial-gradient(circle,rgba(0,255,65,0.09) 0%,transparent 70%);top:-120px;right:4%;"></div>

  <div class="slide-inner">
    <span class="slide-tag">Interfaces</span>
    <h2><span style="color:var(--phosphor);">Interfaces</span></h2>

    <div class="split" style="gap:var(--gap-lg);align-items:start;margin-top:var(--gap);">

      <ul class="bullets" style="gap:0.45em;font-size:var(--small);">
        <li class="fragment fade-up">
          Like abstract classes — but <strong>entirely abstract</strong>: only method signatures, no code
        </li>
        <li class="fragment fade-up">
          Classes <code>extend</code> other classes.<br>Classes <code>implement</code> interfaces.
        </li>
        <li class="fragment fade-up">
          A class can only extend <strong>one</strong> class
        </li>
        <li class="fragment fade-up">
          A class can implement <strong>any number</strong> of interfaces
        </li>
        <li class="fragment fade-up">
          Must implement all interface methods — or be declared <code>abstract</code>
        </li>
        <li class="fragment fade-up">
          Interfaces are also <strong>types</strong>:
          <code>List&lt;String&gt; myList = new ArrayList&lt;&gt;();</code>
        </li>
      </ul>

      <div class="code-card" style="flex:1;">
        <div class="code-hdr">
          <div class="cdot" style="background:#ff5f57;"></div><div class="cdot" style="background:#febc2e;"></div><div class="cdot" style="background:#28c840;"></div>
          <span class="clang">Java</span>
        </div>
        <div class="code-body">
          <pre><span class="kw">public interface</span> <span class="tp">Drawable</span> {
  <span class="kw">void</span> draw();    <span class="cm">// no body</span>
  <span class="kw">void</span> resize(<span class="kw">double</span> factor);
}

<span class="kw">public class</span> <span class="tp">Circle</span>
    <span class="kw">extends</span> <span class="tp">Shape</span>
    <span class="kw">implements</span> <span class="tp">Drawable</span> {

  <span class="nm">@Override</span>
  <span class="kw">public void</span> draw() { <span class="cm">/* … */</span> }

  <span class="nm">@Override</span>
  <span class="kw">public void</span> resize(<span class="kw">double</span> f) { <span class="cm">/* … */</span> }
}</pre>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ============================================================
     SLIDE 23 · COMPARABLE INTERFACE
     ============================================================ -->
<section>
  <div class="glow" style="width:440px;height:440px;background:radial-gradient(circle,rgba(0,255,65,0.10) 0%,transparent 70%);bottom:-60px;right:5%;"></div>

  <div class="slide-inner">
    <span class="slide-tag">Interfaces</span>
    <h2>A common interface: <span style="color:var(--phosphor);">Comparable</span></h2>

    <p style="font-size:var(--body);color:var(--text-muted);max-width:720px;line-height:1.7;margin-bottom:var(--gap);">
      <code>Comparable&lt;T&gt;</code> determines the <strong style="color:var(--text);">natural ordering</strong> of objects — used by sorting methods all over the Java library.
    </p>

    <div class="code-card" style="max-width:760px;">
      <div class="code-hdr">
        <div class="cdot" style="background:#ff5f57;"></div><div class="cdot" style="background:#febc2e;"></div><div class="cdot" style="background:#28c840;"></div>
        <span class="clang">Card.java</span>
      </div>
      <div class="code-body">
        <pre><span class="kw">public class</span> <span class="tp">Card</span> <span class="kw">implements</span> <span class="tp">Comparable</span>&lt;<span class="tp">Card</span>&gt; {

  <span class="kw">private int</span> value;

  <span class="nm">@Override</span>
  <span class="kw">public int</span> compareTo(<span class="tp">Card</span> other) {
    <span class="kw">return this</span>.value - other.value;
    <span class="cm">// negative → this card is less</span>
    <span class="cm">// zero     → equal</span>
    <span class="cm">// positive → this card is greater</span>
  }
}</pre>
      </div>
    </div>

    <div class="callout accent-p fragment fade-up" style="max-width:680px;margin-top:var(--gap);">
      Once a class implements <code>Comparable</code>, you can sort its objects with <code>Collections.sort()</code> and <code>Arrays.sort()</code> for free.
    </div>
  </div>
</section>


<!-- ============================================================
     SLIDE 24 · CLASS DIAGRAMS — IS-A relationships
     ============================================================ -->
<section>
  <div class="glow" style="width:440px;height:440px;background:radial-gradient(circle,rgba(0,255,65,0.09) 0%,transparent 70%);top:-100px;left:4%;"></div>

  <div class="slide-inner">
    <span class="slide-tag">Design</span>
    <h2>Class <span style="color:var(--phosphor);">Diagrams</span></h2>

    <p style="font-size:var(--small);color:var(--text-muted);margin-bottom:var(--gap);">
      Programs contain many classes. Diagrams show inheritance hierarchies at a glance.
    </p>

    <!-- IS-A diagram: Canvas/Shape hierarchy + Main -->
    <div style="display:flex;gap:var(--gap-lg);align-items:flex-start;justify-content:center;">

