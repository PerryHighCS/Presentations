<!-- ============================================================
     SLIDE 25 · HAS-A RELATIONSHIPS
     ============================================================ -->
<section>
  <div class="glow" style="width:440px;height:440px;background:radial-gradient(circle,rgba(255,224,51,0.09) 0%,transparent 70%);bottom:-60px;right:4%;"></div>

  <div class="slide-inner">
    <span class="slide-tag">Design</span>
    <h2><span style="color:var(--phosphor);">HAS-A</span> relationships</h2>

    <p style="font-size:var(--body);color:var(--text-muted);max-width:760px;line-height:1.7;margin-bottom:var(--gap);">
      Not all class relationships are inheritance. When one class <em>owns</em> or <em>uses</em> another, that's <strong style="color:var(--text);">composition</strong> — a HAS-A relationship.
    </p>

    <!-- HAS-A diagram -->
    <div style="display:flex;flex-direction:column;align-items:center;gap:var(--gap);">

      <div style="display:flex;gap:var(--gap-lg);align-items:center;">

        <!-- Forest HAS-A Tree -->
        <div style="display:flex;flex-direction:column;align-items:center;gap:var(--gap-sm);">
          <div class="uml-node" style="font-size:17px;">Forest</div>
          <div style="font-size:12px;color:var(--text-dim);font-style:italic;">has many</div>
          <!-- dashed arrow down -->
          <div style="width:1px;height:20px;border-left:1px dashed rgba(0,255,65,0.35);"></div>
          <div class="uml-node" style="font-size:17px;">Tree</div>
          <div style="font-size:12px;color:var(--text-dim);font-style:italic;">has one of each</div>
          <div style="width:1px;height:20px;border-left:1px dashed rgba(0,255,65,0.35);"></div>
          <div style="display:flex;gap:var(--gap);">
            <div class="uml-node" style="font-size:16px;min-width:80px;">Triangle</div>
            <div class="uml-node" style="font-size:16px;min-width:80px;">Rectangle</div>
          </div>
        </div>

        <!-- VS -->
        <div style="font-size:22px;color:var(--text-dim);padding:0 var(--gap);">vs.</div>

        <!-- IS-A reminder -->
        <div style="display:flex;flex-direction:column;align-items:center;gap:0;">
          <div class="uml-node hi-a" style="font-size:17px;">
            <span class="stereo">&lt;&lt;abstract&gt;&gt;</span>Shape
          </div>
          <div style="width:1px;height:16px;background:var(--phosphor-border);"></div>
          <div style="display:flex;gap:0;border-top:1px solid rgba(0,255,65,0.2);width:220px;">
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;">
              <div style="width:1px;height:14px;background:var(--phosphor-border);"></div>
              <div class="uml-node hi-p" style="font-size:16px;min-width:80px;">Rectangle</div>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;">
              <div style="width:1px;height:14px;background:var(--phosphor-border);"></div>
              <div class="uml-node hi-p" style="font-size:16px;min-width:80px;">Square</div>
            </div>
          </div>
        </div>

      </div>

    </div>

    <!-- Legend -->
    <div style="display:flex;gap:var(--gap-lg);margin-top:var(--gap);font-size:16px;color:var(--text-dim);">
      <div style="display:flex;align-items:center;gap:0.5em;">
        <div style="width:28px;height:0;border-top:1px solid rgba(0,255,65,0.4);"></div>
        <span>IS-A (solid) — inheritance</span>
      </div>
      <div style="display:flex;align-items:center;gap:0.5em;">
        <div style="width:28px;height:0;border-top:1px dashed rgba(0,255,65,0.35);"></div>
        <span>HAS-A (dashed) — composition</span>
      </div>
    </div>
  </div>
</section>


<!-- ============================================================
     SLIDE 26 · END
     ============================================================ -->
<section>
  <div class="glow" style="width:600px;height:600px;background:radial-gradient(circle,rgba(0,255,65,0.11) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);"></div>

  <div class="slide-inner slide-center">
    <span class="slide-tag">AP CSA · Unit 9</span>

    <h1 class="title-h1" style="font-size:72px;">
      <span style="color:var(--phosphor);">That's</span> Inheritance
    </h1>

    <ul class="bullets" style="max-width:640px;gap:0.4em;margin-top:var(--gap-lg);text-align:left;">
      <li><code>extends</code> — IS-A relationship, inherits everything</li>
      <li><code>super</code> — bridge to the parent class</li>
      <li><code>abstract</code> — define the shape, defer the details</li>
      <li><code>implements</code> — promise to provide a behavior</li>
      <li>Polymorphism — same call, different behavior</li>
    </ul>
  </div>
</section>


</div><!-- /.slides -->
</div><!-- /.reveal -->

