    <div style="display:flex;gap:var(--gap-lg);margin-top:var(--gap);font-size:16px;color:var(--text-dim);">
      <div style="display:flex;align-items:center;gap:0.5em;">
        <div style="width:28px;height:1px;background:rgba(0,255,65,0.4);position:relative;">
          <span style="position:absolute;right:-8px;top:-7px;font-size:11px;color:var(--phosphor-dim);">▷</span>
        </div>
        <span>IS-A (solid arrow, open head)</span>
      </div>
      <div style="display:flex;align-items:center;gap:0.5em;">
