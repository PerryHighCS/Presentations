          </div>
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;">
            <div style="width:1px;height:16px;background:var(--phosphor-border);"></div>
            <div class="uml-node" style="font-size:15px;min-width:80px;">Rectangle</div>
            <div style="width:1px;height:14px;background:var(--phosphor-border);"></div>
            <div class="uml-node hi-p" style="font-size:15px;min-width:65px;">Square</div>
          </div>
          <div style="flex:1;display:flex;flex-direction:column;align-items:center;">
            <div style="width:1px;height:16px;background:var(--phosphor-border);"></div>
            <div class="uml-node" style="font-size:15px;min-width:65px;">Arc</div>
